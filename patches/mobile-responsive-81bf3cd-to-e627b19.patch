From e627b199d1de226f9423c8e2ff9f1739b3698bb0 Mon Sep 17 00:00:00 2001
From: MinRosh <info@minroshmigration.com.au>
Date: Tue, 7 Apr 2026 08:38:19 +1000
Subject: [PATCH] fix(mobile): overflow, safe areas, single-column grids, nav
 drawer scroll
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

- Clip/hide horizontal overflow on html/body; body min-width 0; portal-shell 100dvh
- Bento + visual-strip single column ≤1100px; hero grid children min-width 0
- Header padding clamp; brand text min-width 0; MARN pending word-break
- Drawer nav max-width, scroll, safe-area padding; floating tools + AI concierge widths
- ≤720px content-max 100%, safe-area padding on main/header; sticky CTA safe areas
- viewport viewportFit cover for notched devices

Made-with: Cursor
---
 app/globals.css | 76 ++++++++++++++++++++++++++++++++++++++++---------
 app/layout.js   |  1 +
 2 files changed, 64 insertions(+), 13 deletions(-)

diff --git a/app/globals.css b/app/globals.css
index 54e9ef0..cf254d3 100644
--- a/app/globals.css
+++ b/app/globals.css
@@ -35,11 +35,20 @@
 
 html {
   scroll-behavior: smooth;
+  overflow-x: hidden;
+}
+
+@supports (overflow: clip) {
+  html {
+    overflow-x: clip;
+  }
 }
 
 body {
   margin: 0;
-  min-width: 320px;
+  min-width: 0;
+  max-width: 100%;
+  overflow-x: hidden;
   color: var(--ink);
   background:
     radial-gradient(circle at top left, rgba(202, 166, 77, 0.12), transparent 22%),
@@ -52,6 +61,12 @@ body {
   animation: pageFade 0.6s ease both;
 }
 
+@supports (overflow: clip) {
+  body {
+    overflow-x: clip;
+  }
+}
+
 .skip-link {
   position: fixed;
   top: 16px;
@@ -102,6 +117,8 @@ a {
 
 .portal-shell {
   min-height: 100vh;
+  min-height: 100dvh;
+  max-width: 100%;
 }
 
 .site-topbar {
@@ -228,10 +245,11 @@ a {
   max-width: 100%;
   margin: 0 auto;
   min-height: var(--header-height);
-  padding: 0 5vw;
+  padding: 0 clamp(14px, 5vw, 40px);
   display: flex;
   align-items: center;
-  gap: 28px;
+  flex-wrap: nowrap;
+  gap: 12px 16px;
   transition: min-height 0.26s ease;
 }
 
@@ -285,6 +303,7 @@ a.brand:focus-visible {
   flex-direction: column;
   align-items: flex-start;
   gap: 2px;
+  min-width: 0;
 }
 
 .brand__text strong {
@@ -473,6 +492,7 @@ a.brand:focus-visible {
   font-weight: 600;
   color: var(--muted);
   font-size: 0.85rem;
+  word-break: break-word;
 }
 
 .agent-registration-strip__links {
@@ -3094,13 +3114,15 @@ a.brand:focus-visible {
 
 .floating-tools {
   position: fixed;
-  right: 22px;
+  right: max(12px, env(safe-area-inset-right, 0px));
   bottom: calc(20px + env(safe-area-inset-bottom, 0px));
   z-index: 10050;
   display: flex;
   flex-direction: column;
   align-items: flex-end;
   gap: 14px;
+  max-width: calc(100% - 24px);
+  box-sizing: border-box;
 }
 
 .floating-tools.is-open .whatsapp-float {
@@ -3122,7 +3144,8 @@ a.brand:focus-visible {
 }
 
 .ai-concierge {
-  width: min(360px, calc(100vw - 32px));
+  width: min(360px, calc(100vw - 32px - env(safe-area-inset-left, 0px) - env(safe-area-inset-right, 0px)));
+  max-width: 100%;
   border-radius: 28px;
   border: 1px solid var(--line);
   background: rgba(255, 255, 255, 0.98);
@@ -3130,6 +3153,15 @@ a.brand:focus-visible {
   overflow: hidden;
 }
 
+@supports (width: 1dvw) {
+  .ai-concierge {
+    width: min(
+      360px,
+      calc(100dvw - 32px - env(safe-area-inset-left, 0px) - env(safe-area-inset-right, 0px))
+    );
+  }
+}
+
 .ai-concierge__head {
   display: flex;
   align-items: flex-start;
@@ -3423,7 +3455,9 @@ a.brand:focus-visible {
   .quiz-shell,
   .trust-strip,
   .news-grid,
-  .faq-grid {
+  .faq-grid,
+  .bento-grid,
+  .visual-strip {
     grid-template-columns: 1fr;
   }
 
@@ -3451,6 +3485,10 @@ a.brand:focus-visible {
     min-height: auto;
   }
 
+  .hero > * {
+    min-width: 0;
+  }
+
   .hero__media {
     min-height: 320px;
     max-height: none;
@@ -3509,7 +3547,9 @@ a.brand:focus-visible {
     right: 0;
     bottom: 0;
     width: min(360px, 100%);
+    max-width: calc(100vw - 12px);
     padding: 18px;
+    padding-bottom: calc(18px + env(safe-area-inset-bottom, 0px));
     flex-direction: column;
     align-items: stretch;
     justify-content: flex-start;
@@ -3517,6 +3557,9 @@ a.brand:focus-visible {
     transform: translateX(100%);
     transition: transform 0.28s ease;
     box-shadow: -20px 0 50px rgba(8, 21, 40, 0.08);
+    overflow-y: auto;
+    overscroll-behavior: contain;
+    -webkit-overflow-scrolling: touch;
   }
 
   .site-nav__group {
@@ -3564,15 +3607,22 @@ a.brand:focus-visible {
 }
 
 @media (max-width: 720px) {
+  :root {
+    --content-max: 100%;
+    --content-pad: 16px;
+  }
+
   .site-header__inner,
   .portal-main {
-    padding-left: 16px;
-    padding-right: 16px;
+    padding-left: max(14px, env(safe-area-inset-left, 0px));
+    padding-right: max(14px, env(safe-area-inset-right, 0px));
   }
 
   .portal-main {
     padding-top: 16px;
     padding-bottom: 52px;
+    max-width: 100%;
+    box-sizing: border-box;
   }
 
   .site-footer__inner {
@@ -3667,7 +3717,7 @@ a.brand:focus-visible {
   }
 
   .floating-tools {
-    right: 14px;
+    right: max(12px, env(safe-area-inset-right, 0px));
     bottom: calc(86px + env(safe-area-inset-bottom, 0px));
   }
 
@@ -3678,7 +3728,7 @@ a.brand:focus-visible {
   }
 
   .ai-concierge {
-    width: min(340px, calc(100vw - 32px));
+    width: min(340px, calc(100vw - 24px - env(safe-area-inset-left, 0px) - env(safe-area-inset-right, 0px)));
   }
 
   .country-banner span {
@@ -3749,9 +3799,9 @@ a.brand:focus-visible {
 
   .mobile-sticky-cta {
     position: fixed;
-    left: 16px;
-    right: 16px;
-    bottom: 16px;
+    left: max(16px, env(safe-area-inset-left, 0px));
+    right: max(16px, env(safe-area-inset-right, 0px));
+    bottom: max(16px, env(safe-area-inset-bottom, 0px));
     z-index: 65;
     display: inline-flex;
     align-items: center;
diff --git a/app/layout.js b/app/layout.js
index 46a9079..3a16df1 100644
--- a/app/layout.js
+++ b/app/layout.js
@@ -19,6 +19,7 @@ export const viewport = {
   themeColor: "#1e1b4b",
   width: "device-width",
   initialScale: 1,
+  viewportFit: "cover",
 };
 
 export const metadata = {
-- 
2.51.0

