OPENAI_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=info@minroshmigration.com.au
# Default on disk: data/enquiries.json (legacy data-enquiries.json is migrated automatically)
ENQUIRIES_FILE=
BROCHURE_FILE=./public/assets/minrosh-services-brochure.pdf
NEXT_PUBLIC_SITE_URL=https://minroshmigration.com.au
# Server-side URLs for email footers (broadcast). Falls back to NEXT_PUBLIC_SITE_URL if unset.
# PUBLIC_SITE_URL=https://minroshmigration.com.au

# Public upload GET: default is upload-only (no file list). Set true to show existing files on the portal.
# UPLOAD_GET_LISTS_DOCS=false

# If you use a stored bcrypt admin password, env ADMIN_PASSWORD is ignored unless:
# ADMIN_ALLOW_ENV_PASSWORD=true

# JSON security events to stdout for log alerts (failed logins, broadcasts, etc.)
# SECURITY_JSON_LOG=true

# Optional RFC 2369 List-Unsubscribe header (e.g. mailto:you@domain.com?subject=unsubscribe)
# SMTP_LIST_UNSUBSCRIBE=mailto:info@minroshmigration.com.au?subject=Unsubscribe

# Public chat (/api/chat) — optional caps (in-memory per process)
# CHAT_DAILY_MAX_PER_IP=80
# CHAT_DAILY_GLOBAL_MAX=500

# Admin broadcast — recipient count at or above this requires JSON body { broadcastConfirmed: true }
# BROADCAST_LARGE_RECIPIENT_MIN=20

# Production admin POSTs require Origin/Referer from this site. Set true only for scripted access (not recommended).
# ADMIN_ALLOW_NO_ORIGIN=false

# Admin panel (/admin) — required for middleware + login
ADMIN_PASSWORD=change-me-strong-password
# Optional extra secret for session HMAC (defaults to ADMIN_PASSWORD)
ADMIN_SESSION_SECRET=
# Set true only if site is served over HTTPS (secure cookies)
ADMIN_COOKIE_SECURE=false

# Client document upload — magic links expire 72h after issue/regeneration (automatic).

# Optional SMS OTP before upload (Twilio). Set true only after configuring Twilio and storing E.164 mobile on each customer.
# UPLOAD_LINK_SMS_VERIFICATION=false
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+61...
# UPLOAD_SESSION_SECRET=  # HMAC for OTP + session cookie (defaults to ADMIN_SESSION_SECRET / ADMIN_PASSWORD)
# UPLOAD_COOKIE_SECURE=   # omit in dev; set true in production HTTPS
