# Live AI (/api/chat, AI Concierge): set GEMINI_API_KEY and/or OPENAI_API_KEY. If both exist, Gemini is used unless:
#   CHAT_PROVIDER=openai
# Get a Gemini key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional; default is gemini-2.5-flash (see Google AI model docs)
# GEMINI_MODEL=gemini-2.5-flash
# Admin → Intelligence scans: same GEMINI_API_KEY builds headline/summary/body from scraped official text.
# Optional overrides: GEMINI_INTELLIGENCE_MODEL (default gemini-2.5-flash), GEMINI_INTEL_SOURCE_CHARS (default 36000).
# CHAT_PROVIDER=openai

# OpenAI (used when GEMINI_API_KEY is unset, or when CHAT_PROVIDER=openai)
OPENAI_API_KEY=
# Optional public MARN when brand.marn in data/site.json is empty (shown in footer, agent strip, home trust line).
# NEXT_PUBLIC_MARN=18XXXXXX
# --- Google Workspace / Gmail (contact form + brochure) ---
# Use an App Password, not your normal sign-in password:
#   Google Account → Security → 2-Step Verification ON → App passwords → Mail / custom name.
# Paste the 16-character password with or without spaces (the app strips spaces).
#
# PM2: ecosystem.config.js reads THIS file and merges vars into the Node process (works on all PM2 versions).
#       Older PM2 ignored ecosystem "env_file" — that caused "SMTP is not configured" even when .env existed.
#
# Server gotcha: do NOT paste multi-line "VAR=value" lines in bash without quotes.
#   Wrong:  SMTP_PASS=ilfv xbnk fqlk prwe   → bash runs "xbnk" as a command.
#   Right:  put values in THIS file, or use  export SMTP_PASS='ilfv xbnk fqlk prwe'
# Google gives 16 letters only — do not invent underscores (ilfv_xbnk_... is invalid).
#
# "npm run test:smtp" reads only .env in the project root. To test using shell exports instead:
#   npm run test:smtp:shell
#
# Option A — TLS on 587 (typical):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#
# Option B — SSL on 465:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=465
#   SMTP_SECURE=true
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=info@minroshmigration.com.au
SMTP_PASS=
SMTP_FROM=info@minroshmigration.com.au

# Optional GA4 (set before `npm run build` so the ID is in the client bundle)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
#
# Google Search Console: add property for your domain and submit sitemap
#   https://minroshmigration.com.au/sitemap.xml
# Default on disk: data/enquiries.json (legacy data-enquiries.json is migrated automatically)
ENQUIRIES_FILE=
# Contact form: stored on each enquiry as privacyConsentLog (IP, timestamp, policy version, clientConfirmed).
# PRIVACY_POLICY_VERSION=2026-04-14
# When true, POST /api/contact requires JSON { privacyPolicyAccepted: true }.
# REQUIRE_PRIVACY_CONSENT_ON_CONTACT=false
# Post-close upload retention: GET/POST /api/cron/upload-retention (x-cron-secret or Authorization: Bearer).
# Uses UPLOAD_RETENTION_CRON_SECRET, or falls back to NURTURE_CRON_SECRET or CRON_SECRET if unset.
# UPLOAD_RETENTION_CRON_SECRET=
# UPLOAD_RETENTION_DAYS=30
BROCHURE_FILE=./public/assets/minrosh-email-brochure.pdf
NEXT_PUBLIC_SITE_URL=https://minroshmigration.com.au
# Google Calendar auto-booking (optional, for Book Consultation flow)
# Prefer a JSON key file from GCP (absolute path; required when PM2 cwd is .next/standalone):
# GOOGLE_APPLICATION_CREDENTIALS=/home/you/minrosh-migration/.secrets/service-account.json
# Or set email + PEM from the JSON (private_key field); invalid_grant / Invalid signature = wrong or stale key.
# GOOGLE_SERVICE_ACCOUNT_EMAIL=calendar-bot@your-project.iam.gserviceaccount.com
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# GOOGLE_WORKSPACE_DELEGATED_USER=info@minroshmigration.com.au
# GOOGLE_CALENDAR_ID=primary
# Google Drive auto-folders/uploads (optional)
# GOOGLE_DRIVE_LEADS_PARENT_ID=
# GOOGLE_DRIVE_CUSTOMERS_PARENT_ID=
# Drive upload enforcement: set to required for Drive-only mode (no local disk fallback)
# DRIVE_UPLOAD_MODE=required
# Google Sheets visa status tracker (optional; used by private portal page)
# Sheet should include header row with columns: customerId, email, name, status, stage, updatedAt, note
# GOOGLE_SHEETS_STATUS_SPREADSHEET_ID=
# GOOGLE_SHEETS_STATUS_RANGE=PortalStatus!A:Z
# Google Sheets CRM sync (new leads append + admin summary)
# GOOGLE_SHEETS_CRM_SPREADSHEET_ID=
# GOOGLE_SHEETS_CRM_APPEND_RANGE=Leads!A:Z
# GOOGLE_SHEETS_CRM_SUMMARY_RANGE=Leads!A:Z
# Google Places reviews (homepage social proof)
# GOOGLE_PLACES_API_KEY=
# GOOGLE_PLACES_PLACE_ID=
# Cloud Translation API (optional local-language guide snippets)
# GOOGLE_TRANSLATE_API_KEY=
# Google Form webhook secret (for /api/webhooks/google-form). Send header x-webhook-secret: <value>.
# Use at least 16 random characters in production (shorter values are rejected when NODE_ENV=production).
# Optional JSON body fields responseId, submissionId, or idempotencyKey dedupe replays into the same enquiry id.
# GOOGLE_FORM_WEBHOOK_SECRET=
# Landing page pathway map (client-side Google Maps)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Automated nurture sequence scaffold (instant + Day 1 + Day 3) for enquiries — POST /api/cron/nurture with
#   header x-cron-secret: <value>  or  Authorization: Bearer <value>
# Use at least 16 characters in production (shorter values are rejected when NODE_ENV=production).
# NURTURE_CRON_SECRET=change-me-long-random-string
# NURTURE_MAX_PER_RUN=40
# NURTURE_FILE=./data/nurture-queue.json
# Set false to force SMTP only; true/empty uses Gmail API first then SMTP fallback.
# NURTURE_USE_GMAIL_API=true
# Server-side URLs for email footers (broadcast). Falls back to NEXT_PUBLIC_SITE_URL if unset.
# PUBLIC_SITE_URL=https://minroshmigration.com.au

# Public upload GET: default is upload-only (no file list). Set true to show existing files on the portal.
# UPLOAD_GET_LISTS_DOCS=false

# If you use a stored bcrypt admin password, env ADMIN_PASSWORD is ignored unless:
# ADMIN_ALLOW_ENV_PASSWORD=true

# JSON security events to stdout for log alerts (failed logins, broadcasts, etc.)
# SECURITY_JSON_LOG=true
# Structured observability JSON logs (request/cron envelopes, failures). In production this defaults to ON unless set false.
# OBS_JSON_LOG=true

# Optional RFC 2369 List-Unsubscribe header (e.g. mailto:you@domain.com?subject=unsubscribe)
# SMTP_LIST_UNSUBSCRIBE=mailto:info@minroshmigration.com.au?subject=Unsubscribe

# Public chat (/api/chat) — optional caps (in-memory per process)
# CHAT_DAILY_MAX_PER_IP=80
# CHAT_DAILY_GLOBAL_MAX=500

# Admin broadcast — recipient count at or above this requires JSON body { broadcastConfirmed: true }
# BROADCAST_LARGE_RECIPIENT_MIN=20

# Production admin POSTs require Origin/Referer from this site. Set true only for scripted access (not recommended).
# ADMIN_ALLOW_NO_ORIGIN=false

# Admin panel (/admin) — required for middleware + login
ADMIN_PASSWORD=change-me-strong-password
# Session cookie HMAC: Edge middleware reads ONLY env (not data/admin-auth.json).
# REQUIRED: set a long random value. Do not reuse ADMIN_PASSWORD — cookie signing must use its own secret.
ADMIN_SESSION_SECRET=
# Set true only if site is served over HTTPS (secure cookies)
ADMIN_COOKIE_SECURE=false

# Admin RBAC: owner (full) | staff | readonly (read-only). Default owner.
# ADMIN_ROLE=owner
#
# Optional multi-user admins: file data/admin-users.json (gitignored). Super signs in with password only
# (leave email blank on /admin/login), opens Admin → Users, and adds email + password accounts there.
# New admins must verify email (SMTP below); without SMTP, use “Resend verification” after fixing mail.

# Optional TOTP (Google Authenticator) after password. Base32 secret from your authenticator setup.
# ADMIN_TOTP_SECRET=

# Intelligence scan cron: POST /api/cron/intelligence-scan with header x-cron-secret (or Authorization: Bearer …).
# After each run the app emails admin@minroshmigration.com.au (override: INTELLIGENCE_DIGEST_EMAIL or ADMIN_ALERT_EMAIL)
# from info@minroshmigration.com.au (override: SMTP_FROM). Schedule e.g. 1:00 daily: 0 1 * * * bash .../scripts/intelligence-daily-cron.sh
# INTELLIGENCE_CRON_SECRET=change-me-long-random-string
# INTELLIGENCE_DIGEST_EMAIL=admin@minroshmigration.com.au
#
# CRM automation cron (GET /api/cron/crm-automation?secret=...). Falls back to NURTURE_CRON_SECRET if unset.
# CRM_AUTOMATION_CRON_SECRET=

# WhatsApp (or generic) inbound webhook — header x-webhook-secret must match.
# WHATSAPP_WEBHOOK_SECRET=

# Invoice platform (bank transfer only; no card gateway)
# INVOICE_BANK_ACCOUNT_NAME=
# INVOICE_BANK_BSB=
# INVOICE_BANK_ACCOUNT_NUMBER=
# INVOICE_PAYID=info@minroshmigration.com.au
# INVOICE_QR_MODE=plain_text # plain_text (recommended compatibility) | npp_uri (deep-link URI)
# INVOICE_BANK_SWIFT=
# INVOICE_RECURRING_CRON_SECRET=
# INVOICE_REMINDER_CRON_SECRET=
# INVOICE_SYNC_CRON_SECRET=
# INVOICE_FEATURE_RECURRING=true
# INVOICE_FEATURE_PORTAL=true
# INVOICE_FEATURE_THREE_WAY_MATCH=true
# INVOICE_FEATURE_ACCOUNTING_SYNC=true

# Supabase (optional Postgres + Auth). Server routes use service role; never expose SUPABASE_SERVICE_ROLE_KEY to the browser.
# Apply SQL: supabase/migrations/20260212120000_minrosh_db_ping.sql then use Admin → Test Supabase DB.
# Phase 1 dual-write (enquiries): apply supabase/migrations/20260414120000_enquiries_mirror.sql then:
# SUPABASE_DUAL_WRITE_ENQUIRIES=true
# Phase 1 CRM + invoices mirror: apply supabase/migrations/20260415120000_customers_invoices_mirror.sql then:
# SUPABASE_DUAL_WRITE_CUSTOMERS=true
# SUPABASE_DUAL_WRITE_INVOICES=true
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# Optional: upload social poster PNGs to a public Storage bucket (Meta must fetch image_url over HTTPS).
# Create bucket as public, or set policy so anonymous read on path prefix `social/`.
# SOCIAL_SUPABASE_BUCKET=social-posters

# --- Meta (Facebook Page + optional Instagram) — server only; never use NEXT_PUBLIC_ for tokens ---
# Long-lived Page access token with pages_manage_posts (and instagram_content_publish if using IG).
# FACEBOOK_PAGE_ACCESS_TOKEN=
# FACEBOOK_PAGE_ID=
# Optional Graph version (default v21.0)
# FACEBOOK_GRAPH_VERSION=v21.0
# Cron: GET or POST /api/cron/facebook-publish with header x-cron-secret or Authorization: Bearer (same as CRON_SECRET or dedicated):
# FACEBOOK_CRON_SECRET=
# Optional: enqueue publishes to Inngest instead of calling Meta inline from the cron request (durable retries in Inngest Cloud).
# Register app URL + signing key in Inngest; sync functions from /api/inngest.
# FACEBOOK_PUBLISH_USE_INNGEST=false
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=
# Webhook /api/webhooks/facebook-comments: Meta app secret for X-Hub-Signature-256, plus verify token + optional shared secret header
# FACEBOOK_APP_SECRET=
# FACEBOOK_VERIFY_TOKEN=
# FACEBOOK_WEBHOOK_SECRET=
# Signed public URL for generated poster PNGs (HMAC). Required for photo posts unless SOCIAL_SUPABASE_BUCKET is set.
# Use a long random string (16+ chars in production).
# SOCIAL_PUBLISH_IMAGE_SECRET=
# Instagram Business account id (digits). Leave unset to skip IG. Token must include instagram_content_publish.
# INSTAGRAM_BUSINESS_ACCOUNT_ID=
# Set true to publish the same image to Instagram when INSTAGRAM_BUSINESS_ACCOUNT_ID is set.
# SOCIAL_PUBLISH_INSTAGRAM=false
# Optional override for the engagement line appended to captions.
# SOCIAL_CAPTION_ENGAGEMENT_QUESTION=Does this affect your plans? Tell us in the comments.

# Client document upload — magic links expire 72h after issue/regeneration (automatic).

# Optional SMS OTP before upload (Twilio). Set true only after configuring Twilio and storing E.164 mobile on each customer.
# UPLOAD_LINK_SMS_VERIFICATION=false
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+61...
# UPLOAD_SESSION_SECRET=  # HMAC for OTP + upload session (defaults to ADMIN_SESSION_SECRET only)
# UPLOAD_COOKIE_SECURE=   # omit in dev; set true in production HTTPS
