{
  "name": "minrosh-migration-next",
  "version": "2.0.0",
  "private": true,
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "next dev --turbopack -p 3100",
    "generate:brochure": "node scripts/generate-brochure.mjs",
    "generate:admin-session-secret": "node scripts/generate-admin-session-secret.mjs",
    "prebuild:verify": "bash scripts/pre-build-verify.sh",
    "prebuild": "npm run check:sync",
    "cleanup": "node cleanup-dev-files.js",
    "deploy:server": "bash ./deploy-server.sh",
    "build": "node scripts/verify-required-assets.mjs && node scripts/optimize-hero-lcp.mjs && next build && node scripts/copy-standalone-assets.mjs",
    "build:deploy": "npm run build && DEPLOY_CLEANUP=1 npm run cleanup",
    "analyze": "ANALYZE=true npm run build",
    "start": "next start",
    "maintenance:on": "bash scripts/toggle-maintenance.sh on",
    "maintenance:off": "bash scripts/toggle-maintenance.sh off",
    "maintenance:status": "bash scripts/toggle-maintenance.sh status",
    "deploy:update": "bash scripts/update-server.sh",
    "lint": "next lint",
    "test:contact": "node scripts/test-contact-save.mjs",
    "test:invoice": "node scripts/test-invoice-platform.mjs",
    "test:smtp": "node --env-file=.env scripts/test-smtp.mjs",
    "test:smtp:shell": "node scripts/test-smtp.mjs",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:live-mobile": "playwright test e2e/mobile-layout-live.spec.mjs",
    "purge:cdn": "node scripts/purge-cdn.js",
    "test:nav": "node scripts/ui-nav-audit.mjs",
    "install:eslint-next": "npm install eslint-config-next --save-dev --ignore-scripts",
    "routes:verify": "node scripts/reindex-verify.mjs",
    "reindex:verify": "node scripts/reindex-verify.mjs",
    "seo:smoke": "node scripts/reindex-verify.mjs",
    "seo:audit": "node scripts/seo-auto-update.js",
    "seo:auto-update": "node scripts/seo-auto-update.js --write",
    "verify:live-roadmap": "node scripts/live-roadmap-verify.mjs",
    "verify:deploy-html": "node scripts/verify-deploy-html.mjs",
    "check:sync": "node scripts/check-public-admin-sync.mjs",
    "qa": "npm run lint && npm run build",
    "audit:indexability": "node scripts/indexability-audit.mjs",
    "audit:production": "npm audit --production",
    "verify:ci": "npm run lint && npm run test:unit && npm run build && CI=true npm run test:e2e && npm run audit:production",
    "check": "npm run build && npm run test:unit && npm run test:contact && npm run audit:production"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@resvg/resvg-js": "^2.6.2",
    "@supabase/supabase-js": "^2.103.0",
    "@tanstack/react-table": "^8.21.3",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "fflate": "^0.8.2",
    "framer-motion": "^11.18.2",
    "googleapis": "^171.4.0",
    "next": "^15.5.18",
    "nodemailer": "^8.0.4",
    "otplib": "^13.4.0",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "react": "^19.0.6",
    "react-dom": "^19.0.6",
    "satori": "^0.26.0",
    "tailwind-merge": "^3.5.0",
    "tesseract.js": "^5.1.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.9",
    "@playwright/test": "^1.59.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.5.18",
    "inngest": "^3.22.13",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "next": {
      "postcss": "^8.5.10"
    }
  }
}
